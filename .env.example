# ============================================================
# Chat Provider 配置
# ============================================================
# CHAT_PROVIDER=anthropic   # 默认：Anthropic 协议（官方或 new-api/one-api 中转）
# CHAT_PROVIDER=openai      # 切换：OpenAI 兼容协议（Kimi/DeepSeek/OpenAI 等）

# 可选：强制指定模型名（不写则用下方 provider 的默认值）
# CHAT_MODEL=

# ---------- Anthropic（CHAT_PROVIDER=anthropic 时使用） ----------
ANTHROPIC_API_KEY=
# 默认 https://api.anthropic.com；若走中转，改成中转 base url
# ANTHROPIC_BASE_URL=https://newapi2.frontis.top

# ---------- OpenAI 兼容（CHAT_PROVIDER=openai 时使用） ----------
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.moonshot.cn/v1   # Kimi
# OPENAI_MODEL=moonshot-v1-8k                  # 默认 moonshot-v1-8k
