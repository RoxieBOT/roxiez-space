---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postFiles = import.meta.glob('../../content/blog/*.md', { eager: true }) as Record<string, any>;
const slug = Astro.params.slug;
const entry = Object.entries(postFiles).find(([path]) => path.split('/').pop()?.replace('.md', '') === slug);

if (!entry) return Astro.redirect('/blog');

const mod = entry[1] as any;
const Content = mod.Content;
const { title, pubDate } = mod.frontmatter;
---
<BaseLayout title={`${title} · Roxie's Space`}>
  <article class="prose">
    <h1>{title}</h1>
    <div class="post-meta">
      <time datetime={new Date(pubDate).toISOString()}>
        {new Date(pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
    <hr class="divider" />
    <Content />
  </article>
</BaseLayout>
