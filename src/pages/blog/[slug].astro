---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postFiles = import.meta.glob('../../content/blog/*.md', { eager: true }) as Record<string, any>;
const slug = Astro.params.slug;
const entry = Object.entries(postFiles).find(([path]) => path.split('/').pop()?.replace('.md', '') === slug);

if (!entry) return Astro.redirect('/blog');

const mod = entry[1] as any;
const Content = mod.Content;
const { title, pubDate } = mod.frontmatter;
---
<BaseLayout title={`${title} - MySpace`}>
  <article class="prose">
    <h1>{title}</h1>
    <time style="color: var(--text-muted); font-size: .85rem;">{new Date(pubDate).toLocaleDateString('zh-CN')}</time>
    <hr style="border-color: var(--border); margin: 1.5rem 0;" />
    <Content />
  </article>
</BaseLayout>
