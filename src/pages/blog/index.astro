---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const postFiles = import.meta.glob('../../content/blog/*.md', { eager: true }) as Record<string, any>;
const posts = Object.entries(postFiles).map(([path, mod]) => ({
  slug: path.split('/').pop()?.replace('.md', '') ?? '',
  ...mod.frontmatter,
}));
posts.sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
---
<BaseLayout title="博客 - MySpace">
  <h1 class="page-title">博客</h1>
  <div class="card-grid">
    {posts.map(post => (
      <BlogCard
        title={post.title}
        description={post.description}
        pubDate={new Date(post.pubDate).toLocaleDateString('zh-CN')}
        slug={post.slug}
      />
    ))}
  </div>
</BaseLayout>
