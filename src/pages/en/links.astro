---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const links = [
  { name: 'Gmail', url: 'mailto:roxiezhao999@gmail.com', icon: '✉️', descKey: 'links.gmail.desc' as const, action: 'link' },
  { name: 'GitHub', url: 'https://github.com/RoxieBOT', icon: '🐙', descKey: 'links.github.desc' as const, action: 'external' },
  { name: 'WeChat', url: '#wechat', icon: '💬', descKey: 'links.wechat.desc' as const, action: 'wechat' },
  { name: 'AIRoxie', url: '#airoxie', icon: '🤖', descKey: 'links.airoxie.desc' as const, action: 'open-chat' },
];
---
<BaseLayout title={t('links.metaTitle')}>
  <h1 class="page-title">{t('links.title')}</h1>
  <p class="page-subtitle">{t('links.subtitle')}</p>
  <div class="card-grid">
    {links.map(l => (
      <a
        href={l.url}
        class="card link-card"
        target={l.action === 'external' ? '_blank' : undefined}
        rel={l.action === 'external' ? 'noopener noreferrer' : undefined}
        data-action={l.action}
      >
        <span class="icon" aria-hidden="true">{l.icon}</span>
        <div>
          <h3>{l.name}</h3>
          <p>{t(l.descKey)}</p>
        </div>
      </a>
    ))}
  </div>

  <div id="wechat-modal" class="qr-modal hidden" role="dialog" aria-modal="true" aria-labelledby="wechat-modal-title">
    <div class="qr-backdrop" data-close="1"></div>
    <div class="qr-panel">
      <button class="qr-close" aria-label={t('links.modal.close')} data-close="1">&times;</button>
      <h3 id="wechat-modal-title">{t('links.wechat.modalTitle')}</h3>
      <img src="/wechat-qr.png" alt="WeChat QR Code · 星星Roxy" class="qr-img" />
      <button class="qr-copy" data-copy="16621670830" data-copied-prefix={t('links.wechat.copied')} data-copy-fail={t('links.wechat.copyFail')}>{t('links.wechat.copyBtn')}</button>
    </div>
  </div>

  <div id="link-toast" class="link-toast" role="status" aria-live="polite"></div>
</BaseLayout>

<script>
  const toast = document.getElementById('link-toast')!;
  const wechatModal = document.getElementById('wechat-modal')!;
  let toastTimer: number | undefined;

  function showToast(text: string) {
    toast.textContent = text;
    toast.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => toast.classList.remove('show'), 1800);
  }

  function openWechat() {
    wechatModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeWechat() {
    wechatModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLAnchorElement>('a.link-card').forEach((card) => {
    const action = card.dataset.action;
    if (action === 'wechat') {
      card.addEventListener('click', (e) => { e.preventDefault(); openWechat(); });
    }
    if (action === 'open-chat') {
      card.addEventListener('click', (e) => {
        e.preventDefault();
        const toggle = document.getElementById('chat-toggle');
        const win = document.getElementById('chat-window');
        if (win?.classList.contains('hidden')) toggle?.click();
      });
    }
  });

  wechatModal.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.dataset.close) closeWechat();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !wechatModal.classList.contains('hidden')) closeWechat();
  });

  wechatModal.querySelector<HTMLButtonElement>('.qr-copy')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const text = btn.dataset.copy || '';
    const prefix = btn.dataset.copiedPrefix || '';
    const fail = btn.dataset.copyFail || '';
    try {
      await navigator.clipboard.writeText(text);
      showToast(`${prefix}${text}`);
    } catch {
      showToast(fail);
    }
  });
</script>
