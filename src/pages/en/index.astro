---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, localizedPath } from '../../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout title={t('site.title')}>
  <section class="hero">
    <span class="eyebrow">{t('home.eyebrow')}</span>
    <h1>{t('home.greeting.before')} <span class="accent">Roxiez</span> {t('home.greeting.after')}</h1>
    <p>{t('home.intro')}</p>
    <div class="cta">
      <a class="primary" href={localizedPath('/works', lang)}>{t('home.cta.primary')}</a>
      <a href={localizedPath('/blog', lang)}>{t('home.cta.secondary')}</a>
    </div>
  </section>
</BaseLayout>
