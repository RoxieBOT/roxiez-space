---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: '首页' },
  { href: '/works', label: '作品集' },
  { href: '/blog', label: '博客' },
  { href: '/links', label: '链接' },
];
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<nav class="navbar" aria-label="主导航">
  <a class="logo" href="/">Roxiez<span class="logo-tail"> · Roxie's Space</span></a>
  <ul class="nav-links">
    {links.map(l => (
      <li>
        <a
          href={l.href}
          class={isActive(l.href) ? 'active' : ''}
          aria-current={isActive(l.href) ? 'page' : undefined}
        >{l.label}</a>
      </li>
    ))}
  </ul>
</nav>
