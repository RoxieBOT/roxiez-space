---
import NavBar from '../components/NavBar.astro';
import ChatWidget from '../components/ChatWidget.astro';
import '../styles/global.css';

interface Props { title?: string; description?: string; }
const { title = "Roxiez 的数字空间 · Roxie's Space", description = 'Roxiez 的个人站点：营销、GEO、洞察报告与前沿 AI 部署。' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FAF3E6" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <a href="#main" class="skip-link">跳到主内容</a>
  <header class="site-header">
    <NavBar />
  </header>
  <main id="main">
    <slot />
  </main>
  <footer>&copy; {new Date().getFullYear()} Roxiez · Roxie's Space</footer>
  <ChatWidget />
</body>
</html>
