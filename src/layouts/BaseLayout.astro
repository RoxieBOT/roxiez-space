---
import NavBar from '../components/NavBar.astro';
import ChatWidget from '../components/ChatWidget.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import '../styles/global.css';

interface Props { title?: string; description?: string; }

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title = t('site.title'), description = t('site.description') } = Astro.props;
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
---
<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FAF3E6" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <a href="#main" class="skip-link">{t('site.skipLink')}</a>
  <header class="site-header">
    <NavBar />
  </header>
  <main id="main">
    <slot />
  </main>
  <footer>&copy; {new Date().getFullYear()} {t('site.footer')}</footer>
  <ChatWidget />
</body>
</html>
